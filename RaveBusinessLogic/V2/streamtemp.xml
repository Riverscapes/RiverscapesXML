<?xml version="1.0" encoding="utf-8"?>
<Project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:noNamespaceSchemaLocation="http://xml.riverscapes.net/RaveBusinessLogic/XSD/project_explorer.xsd">
  <Name>Stream Temperature</Name>
  <ProjectType>streamtemp</ProjectType>
  <Node xpathlabel="Name">
    <Children collapsed="false">
      <Node label="Stream Temperature" xpath="Realizations/Realization">
        <Children>
          
          <!-- Baseline -->
          <Repeater label="Baseline" xpath="Datasets/Geopackage[@id='OUTPUT']/Layers/Vector[contains(@lyrName, 'stream_temperature') and contains(@lyrName, '_lines') and not(contains(@lyrName, 'anomalies'))]">
            <Node xpathlabel="Name">
              <Children>
                <Node label="Spring" xpath="." type="line" id="sp_stream_temp" symbology="stream_temp_anom_lines" />
                <Node label="Summer" xpath="." type="line" id="su_stream_temp" symbology="stream_temp_anom_lines" />
                <Node label="Fall" xpath="." type="line" id="fa_stream_temp" symbology="stream_temp_anom_lines" />
                <Node label="Winter" xpath="." type="line" id="wi_stream_temp" symbology="stream_temp_anom_lines" />
              </Children>
            </Node>
          </Repeater>

          <!-- Anomalies -->
          <Node label="Anomalies">
             <Children>
               <Repeater label="Lines" xpath="Datasets/Geopackage[@id='OUTPUT']/Layers/Vector[contains(@lyrName, 'stream_temperature_anomalies') and contains(@lyrName, 'lines')]">
                  <Node xpathlabel="Name">
                    <Children>
                       <Node label="Spring" xpath="." type="line" id="sp_stream_temp" symbology="stream_temp_anom_lines" />
                       <Node label="Summer" xpath="." type="line" id="su_stream_temp" symbology="stream_temp_anom_lines" />
                       <Node label="Fall" xpath="." type="line" id="fa_stream_temp" symbology="stream_temp_anom_lines" />
                       <Node label="Winter" xpath="." type="line" id="wi_stream_temp" symbology="stream_temp_anom_lines" />
                    </Children>
                  </Node>
               </Repeater>

                <Node label="Polygons">
                   <Children>
                     <Repeater label="Contributing area" xpath="Datasets/Geopackage[@id='OUTPUT']/Layers/Vector[contains(@lyrName, 'stream_temperature_anomalies') and contains(@lyrName, 'polygons') and not(contains(@lyrName, 'HUC'))]">
                        <Node xpathlabel="Name">
                           <Children>
                              <Node label="Spring" xpath="." type="polygon" id="sp_stream_temp" symbology="stream_temp_anom_polygons" />
                              <Node label="Summer" xpath="." type="polygon" id="su_stream_temp" symbology="stream_temp_anom_polygons" />
                              <Node label="Fall" xpath="." type="polygon" id="fa_stream_temp" symbology="stream_temp_anom_polygons" />
                              <Node label="Winter" xpath="." type="polygon" id="wi_stream_temp" symbology="stream_temp_anom_polygons" />
                           </Children>
                        </Node>
                     </Repeater>

                     <Repeater label="12-digit HUC" xpath="Datasets/Geopackage[@id='OUTPUT']/Layers/Vector[contains(@lyrName, 'stream_temperature_anomalies') and contains(@lyrName, 'byHUC12_polygons')]">
                        <Node xpathlabel="Name">
                           <Children>
                              <Node label="Spring" xpath="." type="polygon" id="sp_stream_temp" symbology="stream_temp_anom_polygons" />
                              <Node label="Summer" xpath="." type="polygon" id="su_stream_temp" symbology="stream_temp_anom_polygons" />
                              <Node label="Fall" xpath="." type="polygon" id="fa_stream_temp" symbology="stream_temp_anom_polygons" />
                              <Node label="Winter" xpath="." type="polygon" id="wi_stream_temp" symbology="stream_temp_anom_polygons" />
                           </Children>
                        </Node>
                     </Repeater>
                   </Children>
                </Node>
             </Children>
          </Node>
          
          <Node label="Log File" xpath="Datasets/File[@id='LOG']" type="file" />

        </Children>
      </Node>
    </Children>
  </Node>
</Project>
