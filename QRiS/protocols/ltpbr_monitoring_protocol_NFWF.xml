				<HierarchyItem>Observations</HierarchyItem>
				<HierarchyItem>Hydraulic Mapping</HierarchyItem>
			</Hierarchy>
			<Fields>
				<ListField id="type_id" version="1.0">
					<Label>Extent Type</Label>
